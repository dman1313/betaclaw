            "style": { "backgroundColor": "transparent", "padding": "36px 28px 16px 28px" },
            "contents": [{
              "type": "text",
              "content": {
                "html": "<p style=\"text-align:center;letter-spacing:2px;text-transform:uppercase;color:#7b6a58;margin:0 0 14px 0;font-size:12px;\">Food Notes</p><h1 style=\"text-align:center;margin:0;color:#2d241d;font-size:34px;line-height:1.2;font-weight:normal;\">Food: What Actually Connects Us</h1><p style=\"text-align:center;color:#6d6257;margin:16px 0 0 0;font-size:17px;line-height:1.6;\">People don’t bond over mission statements. They bond over food.</p>"
              }
            }]
          }]
        },
        {
